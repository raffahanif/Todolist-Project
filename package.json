{
  "name": "todolist-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest --run",
    "electron": "electron .",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "@vitest/ui": "^1.0.0",
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "fast-check": "^3.15.0",
    "jsdom": "^29.0.2",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "build": {
    "appId": "com.todolist.app",
    "productName": "TodoList",
    "asar": true,
    "files": [
      "dist/**/*",
      "main.cjs",
      "package.json"
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    }
  }
}
